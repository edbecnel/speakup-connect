rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ── Helper functions ──────────────────────────────────────────────────────

    function isSignedIn() {
      return request.auth != null;
    }

    function isSuperAdmin() {
      return isSignedIn() && request.auth.token.get('role', '') == 'super_admin';
    }

    function userProfilePath(orgId) {
      return /databases/(default)/documents/organizations/$(orgId)/users/$(request.auth.uid);
    }

    function userProfile(orgId) {
      return firestore.get(userProfilePath(orgId)).data;
    }

    // Profile doc lives under organizations/{orgId}/users/{uid}; path is authoritative
    // for membership. Do not require organizationId field — legacy profiles may omit it.
    function hasApprovedProfile(orgId) {
      return isSignedIn()
          && firestore.exists(userProfilePath(orgId))
          && userProfile(orgId).get('approvalStatus', '') == 'approved';
    }

    // Match Firestore isOrgMember — JWT orgId OR organizationId OR approved profile.
    function isOrgMember(orgId) {
      return isSignedIn()
          && (
            request.auth.token.get('organizationId', '') == orgId
            || request.auth.token.get('orgId', '') == orgId
            || hasApprovedProfile(orgId)
          );
    }

    function isOrgAdmin(orgId) {
      return isSignedIn()
          && (
            (
              (request.auth.token.get('organizationId', '') == orgId
                  || request.auth.token.get('orgId', '') == orgId)
              && request.auth.token.get('role', '') in ['admin', 'owner']
            )
            || (
              hasApprovedProfile(orgId)
              && userProfile(orgId).get('role', '') in ['admin', 'super_admin', 'owner']
            )
          );
    }

    function isAdminOrAbove(orgId) {
      return isSuperAdmin() || isOrgAdmin(orgId);
    }

    function isImage() {
      return request.resource.contentType.matches('image/.*');
    }

    function isUnderSizeLimit(maxMB) {
      return request.resource.size <= maxMB * 1024 * 1024;
    }

    function hasClaimedPermission(permission) {
      return isSignedIn()
          && permission in request.auth.token.get('permissions', []);
    }

    function canManageOfficialPhotos(orgId) {
      return isAdminOrAbove(orgId)
          || hasClaimedPermission('manageClassRoster')
          || hasClaimedPermission('blockUsers');
    }

    function memberProfilePhotosAllowed(orgId) {
      return firestore.get(/databases/(default)/documents/organizations/$(orgId))
          .data.get('allowMemberProfilePhotos', false) == true;
    }

    // ── Organization branding assets ──────────────────────────────────────────
    match /organizations/{orgId}/assets/{fileName} {
      allow read:  if isSuperAdmin() || isOrgMember(orgId);
      allow write: if isAdminOrAbove(orgId)
                   && isImage()
                   && isUnderSizeLimit(5);
    }

    // ── Report photo attachments ──────────────────────────────────────────────
    match /organizations/{orgId}/reports/{reportId}/{fileName} {
      allow read:  if isSuperAdmin() || isOrgMember(orgId);
      allow write: if isOrgMember(orgId)
                   && isImage()
                   && isUnderSizeLimit(10);
    }

    // ── User profile photos ───────────────────────────────────────────────────
    // Personal badge — member uploads their own avatar (org must allow).
    match /organizations/{orgId}/users/{userId}/avatar/{fileName} {
      allow read:  if isSuperAdmin() || isOrgMember(orgId);
      allow write: if isOrgMember(orgId)
                   && request.auth.uid == userId
                   && memberProfilePhotosAllowed(orgId)
                   && isImage()
                   && isUnderSizeLimit(5);
    }

    // Official school photo on a registered member profile.
    match /organizations/{orgId}/users/{userId}/official/{fileName} {
      allow read:  if isSuperAdmin() || isOrgMember(orgId);
      allow write: if canManageOfficialPhotos(orgId)
                   && isImage()
                   && isUnderSizeLimit(5);
    }

    // Official school photo on roster (including not-yet-registered students).
    match /organizations/{orgId}/roster/{studentId}/official/{fileName} {
      allow read:  if isSuperAdmin() || isOrgMember(orgId);
      allow write: if canManageOfficialPhotos(orgId)
                   && isImage()
                   && isUnderSizeLimit(5);
    }

    // ── Bulletin / news post attachments ─────────────────────────────────────
    match /organizations/{orgId}/bulletins/{bulletinId}/{fileName} {
      allow read:  if isSuperAdmin() || isOrgMember(orgId);
      allow write: if isOrgMember(orgId)
                   && isImage()
                   && isUnderSizeLimit(10);
    }

    // ── Apply-to-join: school ID photo uploads ────────────────────────────────
    match /organizations/{orgId}/applications/{userId}/{fileName} {
      allow read:  if isAdminOrAbove(orgId);
      allow write: if isSignedIn()
                   && request.auth.uid == userId
                   && isImage()
                   && isUnderSizeLimit(5);
    }

    // ── Deny all other paths ──────────────────────────────────────────────────
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
