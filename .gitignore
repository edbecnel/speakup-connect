# Generated files (keep in .gitignore to avoid committing build artifacts)
# Note: *.g.dart and *.freezed.dart are typically committed for reliability
# but can be excluded from diffs with the following:
# *.g.dart linguist-generated=true
# *.freezed.dart linguist-generated=true
