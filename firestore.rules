rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ──────────────────────────────────────────────────────

    function isSignedIn() {
      return request.auth != null;
    }

    // Global Super Admin — manages all organizations (web portal only)
    function isSuperAdmin() {
      return isSignedIn() && request.auth.token.get('role', '') == 'super_admin';
    }

    // ── Profile-document fallbacks ────────────────────────────────────────────
    // Used when Cloud Functions have not yet set JWT custom claims.
    // Firebase rules short-circuit ||, so these get() calls are only executed
    // when the JWT claim check (left side) is false.

    function isOrgAdminByProfile(orgId) {
      let p = get(/databases/$(database)/documents/organizations/$(orgId)/users/$(request.auth.uid)).data;
      return p.get('organizationId', '') == orgId
          && p.get('role', '') in ['admin', 'super_admin', 'owner']
          && p.get('approvalStatus', '') == 'approved';
    }

    function isOrgModeratorByProfile(orgId) {
      let p = get(/databases/$(database)/documents/organizations/$(orgId)/users/$(request.auth.uid)).data;
      return p.get('organizationId', '') == orgId
          && p.get('role', '') in ['admin', 'moderator', 'super_admin', 'owner']
          && p.get('approvalStatus', '') == 'approved';
    }

    function isOrgMemberByProfile(orgId) {
      let p = get(/databases/$(database)/documents/organizations/$(orgId)/users/$(request.auth.uid)).data;
      return p.get('organizationId', '') == orgId
          && p.get('approvalStatus', '') == 'approved';
    }

    // Org Admin — full access within their own org
    function isOrgAdmin(orgId) {
      return isSignedIn()
          && (
            (request.auth.token.get('organizationId', '') == orgId
                && request.auth.token.get('role', '') == 'admin')
            || isOrgAdminByProfile(orgId)
          );
    }

    // Moderator or above — can triage reports within their org
    function isOrgModerator(orgId) {
      return isSignedIn()
          && (
            (request.auth.token.get('organizationId', '') == orgId
                && request.auth.token.get('role', '') in ['admin', 'moderator'])
            || isOrgModeratorByProfile(orgId)
          );
    }

    // Any authenticated member of the org
    function isOrgMember(orgId) {
      return isSignedIn()
          && (
            request.auth.token.get('organizationId', '') == orgId
            || isOrgMemberByProfile(orgId)
          );
    }

    // Convenience aliases
    function isAdminOrAbove(orgId) {
      return isSuperAdmin() || isOrgAdmin(orgId);
    }

    function isModeratorOrAbove(orgId) {
      return isSuperAdmin() || isOrgModerator(orgId);
    }

    // Returns true when [orgId] member [uid] has [permission] in their
    // user profile document.  Used to check delegated permissions granted
    // by a super_admin (e.g. 'edit_theme' granted to an admin).
    function hasPermission(orgId, permission) {
      let profile = get(/databases/$(database)/documents/organizations/$(orgId)/users/$(request.auth.uid)).data;
      return permission in profile.get('permissions', []);
    }

    // True when the update only touches branding fields (+ updatedAt).
    // Used to allow delegated admins to update the visual branding without
    // being able to change any other org settings.
    function onlyThemeFields() {
      return request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['displayName', 'primaryColor', 'secondaryColor', 'logoUrl', 'tagline', 'welcomeMessage', 'updatedAt']);
    }

    // ── Organizations ─────────────────────────────────────────────────────────

    match /organizations/{orgId} {
      // Any signed-in user can read org metadata (branding, name, colors).
      // isOrgMember requires the organizationId custom claim which new users
      // don't have yet, so we allow any authenticated user to read org docs.
      allow read: if isSuperAdmin() || isSignedIn();

      // Super Admin has unrestricted write access
      allow create, delete: if isSuperAdmin();

      // Full update: super_admin only
      // Partial update (theme fields only): super_admin OR admin with 'edit_theme' permission
      allow update: if isSuperAdmin()
                    || (isOrgAdmin(orgId)
                        && hasPermission(orgId, 'edit_theme')
                        && onlyThemeFields());

      // ── Config ─────────────────────────────────────────────────────────────
      match /config/{configId} {
        // Any signed-in user can read org config (branding, name, tagline).
        // Needed so the Apply-to-Join screen shows org info before the user
        // has an organizationId custom claim.
        allow read:  if isSuperAdmin() || isSignedIn();
        allow write: if isAdminOrAbove(orgId);
      }

      // ── Report Categories ───────────────────────────────────────────────────
      // Categories are non-sensitive (display names + icons only). Any
      // signed-in user may read them — needed before custom claims propagate
      // and for the Apply-to-Join flow where the user has no organizationId
      // claim yet. Same rationale as the /config rule above.
      match /categories/{categoryId} {
        allow read:  if isSignedIn();
        allow write: if isAdminOrAbove(orgId);
      }

      // ── Reports ─────────────────────────────────────────────────────────────
      // Security model:
      //   - Moderators+ can read all reports in the org
      //   - Normal members can only read their own non-anonymous reports
      //   - adminNotes field is never returned to non-admin users
      //     (field-level filtering is enforced in app code + Cloud Functions;
      //      Firestore Security Rules do not support field-level redaction natively)
      match /reports/{reportId} {
        allow read: if isModeratorOrAbove(orgId)
                    || (isOrgMember(orgId)
                        && resource.data.isAnonymous == false
                        && resource.data.submittedBy == request.auth.uid);

        allow create: if isOrgMember(orgId)
                      && request.resource.data.organizationId == orgId
                      && (request.resource.data.isAnonymous == true
                          || request.resource.data.submittedBy == request.auth.uid);

        // Only moderators+ may update (status changes, triage, notes)
        allow update: if isModeratorOrAbove(orgId);

        // Only org admin+ may delete
        allow delete: if isAdminOrAbove(orgId);
      }

      // ── User Profiles ───────────────────────────────────────────────────────
      match /users/{userId} {
        // Admins can read all profiles; users can read their own.
        // Note: isSignedIn() only (not isOrgMember) so that newly signed-up
        // users without an organizationId custom claim can still watch their
        // own profile during the pending-approval flow.
        allow read: if isAdminOrAbove(orgId)
                    || (isSignedIn() && request.auth.uid == userId);

        // Users may create their own profile; admins may create any
        allow create: if isSuperAdmin()
                      || isAdminOrAbove(orgId)
                      || (isSignedIn()
                          && request.auth.uid == userId
                          && request.resource.data.organizationId == orgId);

        // Users may update their own profile; admins may update any.
        // IMPORTANT: only super_admin may modify the 'permissions' field —
        // prevents privilege escalation by admins or self-granting.
        allow update: if isSuperAdmin()
                      || (isAdminOrAbove(orgId)
                          && !request.resource.data.diff(resource.data)
                              .affectedKeys().hasAny(['permissions']))
                      || (isOrgMember(orgId)
                          && request.auth.uid == userId
                          && !request.resource.data.diff(resource.data)
                              .affectedKeys().hasAny(['permissions', 'role']));

        allow delete: if isAdminOrAbove(orgId);
      }

      // ── Admin Records ───────────────────────────────────────────────────────
      match /admins/{adminId} {
        allow read: if isAdminOrAbove(orgId)
                    || (isOrgMember(orgId) && request.auth.uid == adminId);
        allow write: if isAdminOrAbove(orgId);
      }

      // ── Student/Member Roster ───────────────────────────────────────────────
      // Roster is sensitive (student IDs + names). Admin-only reads.
      // Roster verification at signup is done server-side via Admin SDK.
      match /roster/{studentId} {
        allow read:  if isAdminOrAbove(orgId);
        allow write: if isAdminOrAbove(orgId);
      }

      // ── Custom Roles ────────────────────────────────────────────────────────
      match /roles/{roleId} {
        allow read:  if isSuperAdmin() || isOrgMember(orgId);
        allow write: if isAdminOrAbove(orgId);
      }

      // ── Groups ──────────────────────────────────────────────────────────────
      match /groups/{groupId} {
        allow read:   if isSuperAdmin() || isOrgMember(orgId);
        allow create: if isAdminOrAbove(orgId);
        allow update: if isAdminOrAbove(orgId);
        allow delete: if isAdminOrAbove(orgId);

        // Group membership
        match /members/{memberId} {
          allow read:  if isSuperAdmin() || isOrgMember(orgId);
          allow write: if isAdminOrAbove(orgId);
        }
      }

      // ── Bulletins ───────────────────────────────────────────────────────────
      match /bulletins/{bulletinId} {
        allow read:  if isSuperAdmin() || isOrgMember(orgId);
        allow write: if isModeratorOrAbove(orgId);
      }

      // ── News Posts ──────────────────────────────────────────────────────────
      match /newsPosts/{postId} {
        allow read:   if isSuperAdmin() || isOrgMember(orgId);

        // Members can create their own posts (group leader/teacher permissions
        // enforced at app layer via customRoles field)
        allow create: if isOrgMember(orgId)
                      && request.resource.data.organizationId == orgId
                      && request.resource.data.authorId == request.auth.uid;

        // Authors can edit their own posts; admins can edit any
        allow update: if isAdminOrAbove(orgId)
                      || (isOrgMember(orgId)
                          && resource.data.authorId == request.auth.uid);

        allow delete: if isAdminOrAbove(orgId)
                      || (isOrgMember(orgId)
                          && resource.data.authorId == request.auth.uid);
      }

      // ── Reminders / Broadcasts ──────────────────────────────────────────────
      match /reminders/{reminderId} {
        allow read:   if isSuperAdmin() || isOrgMember(orgId);
        allow create: if isAdminOrAbove(orgId);
        allow update: if isAdminOrAbove(orgId);
        allow delete: if isAdminOrAbove(orgId);
      }

      // ── Group Chat Messages ─────────────────────────────────────────────────
      match /messages/{threadId} {
        allow read:   if isSuperAdmin() || isOrgMember(orgId);
        allow create: if isAdminOrAbove(orgId);
        allow update: if isAdminOrAbove(orgId);
        allow delete: if isAdminOrAbove(orgId);

        match /entries/{messageId} {
          allow read:   if isSuperAdmin() || isOrgMember(orgId);
          allow create: if isOrgMember(orgId)
                        && request.resource.data.senderId == request.auth.uid;
          allow update: if isAdminOrAbove(orgId)
                        || (isOrgMember(orgId)
                            && resource.data.senderId == request.auth.uid);
          allow delete: if isAdminOrAbove(orgId);
        }
      }

      // ── Direct Messages ─────────────────────────────────────────────────────
      match /directMessages/{threadId} {
        allow read: if isSuperAdmin()
                    || (isOrgMember(orgId)
                        && request.auth.uid in resource.data.participantIds);

        allow create: if isOrgMember(orgId)
                      && request.auth.uid in request.resource.data.participantIds
                      && request.resource.data.organizationId == orgId;

        allow update: if isSuperAdmin()
                      || (isOrgMember(orgId)
                          && request.auth.uid in resource.data.participantIds);

        allow delete: if isAdminOrAbove(orgId);

        match /entries/{messageId} {
          // get() check validates the user is a thread participant before reading messages
          allow read: if isSuperAdmin()
                      || (isOrgMember(orgId)
                          && request.auth.uid in
                             get(/databases/$(database)/documents/organizations/$(orgId)/directMessages/$(threadId)).data.participantIds);

          allow create: if isOrgMember(orgId)
                        && request.resource.data.senderId == request.auth.uid
                        && request.auth.uid in
                           get(/databases/$(database)/documents/organizations/$(orgId)/directMessages/$(threadId)).data.participantIds;

          allow update: if isAdminOrAbove(orgId)
                        || (isOrgMember(orgId)
                            && resource.data.senderId == request.auth.uid);

          allow delete: if isAdminOrAbove(orgId);
        }
      }

      // ── Blocked Users ───────────────────────────────────────────────────────
      match /blockedUsers/{blockId} {
        allow read:  if isAdminOrAbove(orgId);
        allow write: if isAdminOrAbove(orgId);
      }

      // ── Community Rules ─────────────────────────────────────────────────────
      match /communityRules/{ruleId} {
        allow read:  if isSuperAdmin() || isOrgMember(orgId);
        allow write: if isAdminOrAbove(orgId);
      }
    }

    // ── Global Language Database ──────────────────────────────────────────────
    // Read by any authenticated user; write by Super Admin only
    match /languages/{languageCode} {
      allow read:  if isSignedIn();
      allow write: if isSuperAdmin();

      match /strings/{stringKey} {
        allow read:  if isSignedIn();
        allow write: if isSuperAdmin();
      }
    }

    // ── Platform Collection (Super Admin only) ────────────────────────────────
    match /platform/{document=**} {
      allow read, write: if isSuperAdmin();
    }

    // ── Default deny — reject all unmatched paths ─────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
