rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ──────────────────────────────────────────────────────

    function isSignedIn() {
      return request.auth != null;
    }

    // Global Super Admin — manages all organizations (web portal only)
    function isSuperAdmin() {
      return isSignedIn() && request.auth.token.get('role', '') == 'super_admin';
    }

    // ── Profile-document fallbacks ────────────────────────────────────────────
    // Used when Cloud Functions have not yet set JWT custom claims.
    // Firebase rules short-circuit ||, so these get() calls are only executed
    // when the JWT claim check (left side) is false.

    function isOrgAdminByProfile(orgId) {
      let p = get(/databases/$(database)/documents/organizations/$(orgId)/users/$(request.auth.uid)).data;
      return p.get('organizationId', '') == orgId
          && p.get('role', '') in ['admin', 'super_admin', 'owner']
          && p.get('approvalStatus', '') == 'approved';
    }

    function isOrgModeratorByProfile(orgId) {
      let p = get(/databases/$(database)/documents/organizations/$(orgId)/users/$(request.auth.uid)).data;
      return p.get('organizationId', '') == orgId
          && p.get('role', '') in ['admin', 'moderator', 'super_admin', 'owner']
          && p.get('approvalStatus', '') == 'approved';
    }

    function isOrgMemberByProfile(orgId) {
      let p = get(/databases/$(database)/documents/organizations/$(orgId)/users/$(request.auth.uid)).data;
      return p.get('organizationId', '') == orgId
          && p.get('approvalStatus', '') == 'approved';
    }

    // Org Admin — full access within their own org
    function isOrgAdmin(orgId) {
      return isSignedIn()
          && (
            (request.auth.token.get('organizationId', '') == orgId
                && request.auth.token.get('role', '') == 'admin')
            || isOrgAdminByProfile(orgId)
          );
    }

    // Moderator or above — can triage reports within their org
    function isOrgModerator(orgId) {
      return isSignedIn()
          && (
            (request.auth.token.get('organizationId', '') == orgId
                && request.auth.token.get('role', '') in ['admin', 'moderator'])
            || isOrgModeratorByProfile(orgId)
          );
    }

    // Any authenticated member of the org
    function isOrgMember(orgId) {
      return isSignedIn()
          && (
            request.auth.token.get('organizationId', '') == orgId
            || isOrgMemberByProfile(orgId)
          );
    }

    // Approved member — used for roster pickers (group leaders, etc.).
    function isApprovedOrgMember(orgId) {
      return isSignedIn()
          && exists(/databases/$(database)/documents/organizations/$(orgId)/users/$(request.auth.uid))
          && get(/databases/$(database)/documents/organizations/$(orgId)/users/$(request.auth.uid)).data.get('organizationId', '') == orgId
          && get(/databases/$(database)/documents/organizations/$(orgId)/users/$(request.auth.uid)).data.get('approvalStatus', '') == 'approved';
    }

    // Convenience aliases
    function isAdminOrAbove(orgId) {
      return isSuperAdmin() || isOrgAdmin(orgId);
    }

    function isModeratorOrAbove(orgId) {
      return isSuperAdmin() || isOrgModerator(orgId);
    }

    // RBAC report triage — holders of viewAllReports / manageReports via JWT
    // or delegated profile permissions (org-admin role, discipline officer, etc.).
    function canViewOrgReports(orgId) {
      return isModeratorOrAbove(orgId)
          || hasClaimedPermission('viewAllReports')
          || hasClaimedPermission('manageReports')
          || hasPermission(orgId, 'viewAllReports')
          || hasPermission(orgId, 'manageReports');
    }

    function canManageOrgReports(orgId) {
      return isModeratorOrAbove(orgId)
          || hasClaimedPermission('manageReports')
          || hasPermission(orgId, 'manageReports');
    }

    // Returns true when [orgId] member [uid] has [permission] in their
    // user profile document.  Used to check delegated permissions granted
    // by a super_admin (e.g. 'edit_theme' granted to an admin).
    // True when the requesting user has [permission] in their Firebase Auth
    // custom claims. JWT-first — no Firestore read required.
    // Claims are synced by the syncCustomClaims Cloud Function on every role
    // assignment write. May lag by up to 1 hour on role *definition* changes
    // unless refreshMyPermissions is called and the app force-refreshes its token.
    function hasClaimedPermission(permission) {
      return isSignedIn()
          && permission in request.auth.token.get('permissions', []);
    }

    // True when [orgId] member [uid] has [permission].
    // Checks the Firebase Auth JWT claim first (no read cost), then falls back
    // to the user profile document (for users whose claims have not yet synced).
    function hasPermission(orgId, permission) {
      return hasClaimedPermission(permission)
          || permission in get(/databases/$(database)/documents/organizations/$(orgId)/users/$(request.auth.uid)).data.get('permissions', []);
    }

    // True when the requester may publish a reminder immediately (status
    // 'published') rather than submitting it for approval. Either they are an
    // admin / approver, or the org does not require reminder approval.
    function canPublishRemindersDirectly(orgId) {
      return isAdminOrAbove(orgId)
          || hasClaimedPermission('approveReminders')
          || get(/databases/$(database)/documents/organizations/$(orgId)).data.get('requireReminderApproval', false) == false;
    }

    // True when the signed-in user is a leader of [groupId] in [orgId].
    // Checks roster and per-user groupMemberships index (My Groups).
    function isGroupLeader(orgId, groupId) {
      return isSignedIn()
          && (
            (exists(/databases/$(database)/documents/organizations/$(orgId)/groups/$(groupId)/members/$(request.auth.uid))
                && get(/databases/$(database)/documents/organizations/$(orgId)/groups/$(groupId)/members/$(request.auth.uid)).data.get('groupRole', '') == 'leader')
            || (exists(/databases/$(database)/documents/organizations/$(orgId)/users/$(request.auth.uid)/groupMemberships/$(groupId))
                && get(/databases/$(database)/documents/organizations/$(orgId)/users/$(request.auth.uid)/groupMemberships/$(groupId)).data.get('groupRole', '') == 'leader')
          );
    }

    // Group leaders may only touch roster-related metadata on the group document.
    function onlyGroupLeaderGroupUpdate() {
      let keys = request.resource.data.diff(resource.data).affectedKeys();
      return keys.hasOnly(['updatedAt'])
          || keys.hasOnly(['memberCount', 'updatedAt']);
    }

    // Group leaders may create reminders targeted only at a group they lead.
    function canCreateGroupLeaderReminder(orgId) {
      return request.resource.data.createdBy == request.auth.uid
          && request.resource.data.get('audienceType', '') == 'group'
          && request.resource.data.get('audienceId', '') != ''
          && isGroupLeader(orgId, request.resource.data.audienceId)
          && (
            request.resource.data.status == 'pending'
            || (request.resource.data.status == 'published'
                && canPublishRemindersDirectly(orgId))
          );
    }

    // True when the update only touches branding fields (+ updatedAt).
    // Used to allow delegated admins to update the visual branding without
    // being able to change any other org settings.
    function onlyThemeFields() {
      return request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['displayName', 'primaryColor', 'secondaryColor', 'logoUrl', 'tagline', 'welcomeMessage', 'updatedAt']);
    }

    // True when the update only touches the reminder-approval toggle
    // (+ updatedAt). Lets org admins / manageOrganizationSettings holders flip
    // requireReminderApproval without granting broad org-document write access.
    function onlyReminderApprovalFields() {
      return request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['requireReminderApproval', 'updatedAt']);
    }

    // Join-application review — approvalStatus and related audit fields only.
    function onlyJoinApprovalFields() {
      return request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly([
            'approvalStatus',
            'applicationSubmitted',
            'reviewedBy',
            'reviewedAt',
            'rejectionReason',
            'updatedAt',
          ]);
    }

    // Block / unblock enrolled members — isActive and block audit fields only.
    function onlyBlockUserFields() {
      return request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly([
            'isActive',
            'blockReason',
            'blockedAt',
            'blockedBy',
            'updatedAt',
          ]);
    }

    // Roster grade updates — grade field only.
    function onlyRosterGradeFields() {
      return request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['grade', 'updatedAt']);
    }

    // Member grade on enrolled profile.
    function onlyGradeLevelFields() {
      return request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['gradeLevel', 'updatedAt']);
    }

    // Unenroll members — approval status and audit fields only.
    function onlyUnenrollFields() {
      return request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly([
            'approvalStatus',
            'unenrollReason',
            'unenrolledAt',
            'unenrolledBy',
            'updatedAt',
          ]);
    }

    // School grade levels on the org document (school-type clients only).
    function onlyGradeLevelsFields() {
      return request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['gradeLevels', 'updatedAt']);
    }

    // Organization type (school, NGO, municipality, etc.).
    function onlyOrganizationTypeFields() {
      return request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['type', 'updatedAt']);
    }

    // Re-enroll former members — restore approved status and clear unenroll audit.
    function onlyReEnrollFields() {
      return request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly([
            'approvalStatus',
            'isActive',
            'unenrollReason',
            'unenrolledAt',
            'unenrolledBy',
            'updatedAt',
          ]);
    }

    // ── Organizations ─────────────────────────────────────────────────────────

    match /organizations/{orgId} {
      // Any signed-in user can read org metadata (branding, name, colors).
      // isOrgMember requires the organizationId custom claim which new users
      // don't have yet, so we allow any authenticated user to read org docs.
      allow read: if isSuperAdmin() || isSignedIn();

      // Super Admin has unrestricted write access
      allow create, delete: if isSuperAdmin();

      // Full update: super_admin only
      // Partial update (theme fields only): super_admin OR org admin OR
      // any role that has been explicitly granted the 'edit_theme' permission
      allow update: if isSuperAdmin()
                    || (isAdminOrAbove(orgId) && onlyThemeFields())
                    || (isOrgModerator(orgId)
                        && hasPermission(orgId, 'edit_theme')
                        && onlyThemeFields())
                    || ((isAdminOrAbove(orgId)
                         || hasClaimedPermission('manageOrganizationSettings'))
                        && onlyReminderApprovalFields())
                    || ((isAdminOrAbove(orgId)
                         || hasClaimedPermission('manageOrganizationSettings'))
                        && onlyGradeLevelsFields())
                    || ((isAdminOrAbove(orgId)
                         || hasClaimedPermission('manageOrganizationSettings'))
                        && onlyOrganizationTypeFields());

      // ── Config ─────────────────────────────────────────────────────────────
      match /config/{configId} {
        // Any signed-in user can read org config (branding, name, tagline).
        // Needed so the Apply-to-Join screen shows org info before the user
        // has an organizationId custom claim.
        allow read:  if isSuperAdmin() || isSignedIn();
        allow write: if isAdminOrAbove(orgId);
      }

      // ── Report Categories ───────────────────────────────────────────────────
      // Categories are non-sensitive (display names + icons only). Any
      // signed-in user may read them — needed before custom claims propagate
      // and for the Apply-to-Join flow where the user has no organizationId
      // claim yet. Same rationale as the /config rule above.
      match /categories/{categoryId} {
        allow read:  if isSignedIn();
        allow write: if isAdminOrAbove(orgId);
      }

      // ── Reference Number Counters ───────────────────────────────────────────
      // Counters are used by _generateReferenceNumber() to produce sequential,
      // unique report reference numbers (e.g. MONHS-2026-000001) via a
      // Firestore transaction. Any org member may read+write — the transaction
      // itself ensures atomicity; the worst-case race produces a higher number,
      // not a collision. Admins must also be allowed to reset counters.
      match /counters/{counterId} {
        allow read, write: if isOrgMember(orgId);
      }

      // ── Reports ─────────────────────────────────────────────────────────────
      // Security model:
      //   - Moderators+ can read all reports in the org
      //   - Normal members can only read their own non-anonymous reports
      //   - adminNotes field is never returned to non-admin users
      //     (field-level filtering is enforced in app code + Cloud Functions;
      //      Firestore Security Rules do not support field-level redaction natively)
      match /reports/{reportId} {
        allow read: if canViewOrgReports(orgId)
                    || (isOrgMember(orgId)
                        && resource.data.isAnonymous == false
                        && resource.data.submittedBy == request.auth.uid);

        allow create: if isOrgMember(orgId)
                      && request.resource.data.organizationId == orgId
                      && (request.resource.data.isAnonymous == true
                          || request.resource.data.submittedBy == request.auth.uid);

        // Status changes, triage, and admin notes.
        allow update: if canManageOrgReports(orgId);

        // Only org admin+ may delete
        allow delete: if isAdminOrAbove(orgId);
      }

      // ── User Profiles ───────────────────────────────────────────────────────
      match /users/{userId} {
        // Admins can read all profiles; users can read their own.
        // Note: isSignedIn() only (not isOrgMember) so that newly signed-up
        // users without an organizationId custom claim can still watch their
        // own profile during the pending-approval flow.
        allow read: if isAdminOrAbove(orgId)
                    || hasPermission(orgId, 'approveApplications')
                    || hasPermission(orgId, 'blockUsers')
                    || (isSignedIn() && request.auth.uid == userId)
                    || (isApprovedOrgMember(orgId)
                        && resource.data.get('approvalStatus', '') == 'approved');

        // Users may create their own profile; admins may create any
        allow create: if isSuperAdmin()
                      || isAdminOrAbove(orgId)
                      || (isSignedIn()
                          && request.auth.uid == userId
                          && request.resource.data.organizationId == orgId);

        // Users may update their own profile; admins may update any.
        // IMPORTANT: only super_admin may modify the 'permissions' field —
        // prevents privilege escalation by admins or self-granting.
        allow update: if isSuperAdmin()
                      || (isAdminOrAbove(orgId)
                          && !request.resource.data.diff(resource.data)
                              .affectedKeys().hasAny(['permissions']))
                      || (hasPermission(orgId, 'approveApplications')
                          && onlyJoinApprovalFields())
                      || (hasPermission(orgId, 'blockUsers')
                          && onlyBlockUserFields())
                      || (hasPermission(orgId, 'blockUsers')
                          && onlyUnenrollFields())
                      || (hasPermission(orgId, 'blockUsers')
                          && onlyReEnrollFields())
                      || (hasPermission(orgId, 'manageClassRoster')
                          && onlyGradeLevelFields())
                      || (isOrgMember(orgId)
                          && request.auth.uid == userId
                          && !request.resource.data.diff(resource.data)
                              .affectedKeys().hasAny(['permissions', 'role']));

        allow delete: if isAdminOrAbove(orgId);

        // ── Role Assignments ──────────────────────────────────────────────────
        // Subcollection tracking which roles this user holds, each with a
        // scopeType and optional scopeId. Writes trigger the syncCustomClaims
        // Cloud Function which refreshes the user's Firebase Auth custom claims.
        match /roleAssignments/{assignmentId} {
          // Users can read their own assignments; admins can read any.
          allow read: if isAdminOrAbove(orgId)
                      || (isSignedIn() && request.auth.uid == userId);
          // Org admins may always write. Holders of manageRoles may write,
          // but only within their own org (orgId claim check prevents
          // cross-org privilege escalation).
          allow write: if isAdminOrAbove(orgId)
                       || (hasClaimedPermission('manageRoles')
                           && request.auth.token.get('orgId', '') == orgId);
        }

        // ── Group membership index (My Groups) ───────────────────────────────
        // Denormalized list of groups this user belongs to. Readable by the
        // member; written by roster managers when adding/removing members.
        match /groupMemberships/{groupId} {
          allow read: if isAdminOrAbove(orgId)
                      || (isSignedIn() && request.auth.uid == userId);
          allow write: if isAdminOrAbove(orgId)
                       || hasClaimedPermission('manageGroupRoster')
                       || isGroupLeader(orgId, groupId);
        }

        // ── In-App Notification Feed ─────────────────────────────────────────
        // Per-user feed written server-side by Cloud Functions (Admin SDK,
        // which bypasses these rules). Clients may only read their own feed and
        // flip the read/readAt fields when opening a notification.
        match /notifications/{notificationId} {
          allow read: if isAdminOrAbove(orgId)
                      || (isSignedIn() && request.auth.uid == userId);
          // Owner may mark as read — restricted to the read/readAt fields only.
          allow update: if isSignedIn()
                        && request.auth.uid == userId
                        && request.resource.data.diff(resource.data)
                            .affectedKeys().hasOnly(['read', 'readAt']);
          allow delete: if (isSignedIn() && request.auth.uid == userId)
                        || isAdminOrAbove(orgId);
          // Client creates are not allowed — only Cloud Functions write feed entries.
          allow create: if false;
        }
      }

      // ── Admin Records ───────────────────────────────────────────────────────
      match /admins/{adminId} {
        allow read: if isAdminOrAbove(orgId)
                    || (isOrgMember(orgId) && request.auth.uid == adminId);
        allow write: if isAdminOrAbove(orgId);
      }

      // ── Student/Member Roster ───────────────────────────────────────────────
      // Roster is sensitive (student IDs + names). Admin-only reads.
      // Roster verification at signup is done server-side via Admin SDK.
      match /roster/{studentId} {
        allow read:  if isAdminOrAbove(orgId)
                     || hasPermission(orgId, 'blockUsers')
                     || hasPermission(orgId, 'manageClassRoster');
        allow create, delete: if isAdminOrAbove(orgId);
        allow update: if isAdminOrAbove(orgId)
                      || (hasPermission(orgId, 'manageClassRoster')
                          && onlyRosterGradeFields());
      }

      // ── Custom Roles ────────────────────────────────────────────────────────
      match /roles/{roleId} {
        allow read:  if isSuperAdmin() || isOrgMember(orgId);
        allow write: if isAdminOrAbove(orgId)
                     || (hasClaimedPermission('manageRoles')
                         && request.auth.token.get('orgId', '') == orgId);
      }

      // ── Custom Capabilities ─────────────────────────────────────────────────
      // Org-defined aliases that map a display name to a built-in AppPermission.
      // Only org admins and manageRoles holders may create or edit them.
      match /customCapabilities/{capId} {
        allow read:  if isSuperAdmin() || isOrgMember(orgId);
        allow write: if isAdminOrAbove(orgId)
                     || (hasClaimedPermission('manageRoles')
                         && request.auth.token.get('orgId', '') == orgId);
      }

      // ── Groups ──────────────────────────────────────────────────────────────
      // Group creation/deletion is org-admin only; roster edits also allowed
      // for holders of the manageGroupRoster permission (club advisers, etc.).
      match /groups/{groupId} {
        allow read:   if isSuperAdmin() || isOrgMember(orgId);
        allow create: if isAdminOrAbove(orgId);
        allow update: if isAdminOrAbove(orgId)
                      || hasClaimedPermission('manageGroupRoster')
                      || (isGroupLeader(orgId, groupId)
                          && onlyGroupLeaderGroupUpdate());
        allow delete: if isAdminOrAbove(orgId);

        match /members/{memberId} {
          allow read:  if isSuperAdmin() || isOrgMember(orgId);
          allow write: if isAdminOrAbove(orgId)
                       || hasClaimedPermission('manageGroupRoster')
                       || isGroupLeader(orgId, groupId);
        }
      }

      // ── Classes (school-only academic units) ────────────────────────────────
      // Each class has a members subcollection for roster management.
      // The manageClassRoster permission (school OrgType only) gates writes;
      // org admins always have full access regardless of OrgType.
      match /classes/{classId} {
        allow read:   if isSuperAdmin() || isOrgMember(orgId);
        allow create: if isAdminOrAbove(orgId)
                      || hasClaimedPermission('manageClassRoster');
        allow update: if isAdminOrAbove(orgId)
                      || hasClaimedPermission('manageClassRoster');
        allow delete: if isAdminOrAbove(orgId);

        match /members/{memberId} {
          allow read:  if isSuperAdmin() || isOrgMember(orgId);
          allow write: if isAdminOrAbove(orgId)
                       || hasClaimedPermission('manageClassRoster');
        }
      }

      // ── Counselor Contact Requests (voluntary_contact anonymityMode) ──────────
      // Stores the reporter's optional consent to be contacted by a counselor
      // after an anonymous report. Intentionally NOT linked to the report
      // document so the report remains genuinely anonymous.
      match /counselorContactRequests/{requestId} {
        allow read: if isModeratorOrAbove(orgId);
        allow create: if isOrgMember(orgId)
                      && request.resource.data.organizationId == orgId;
        allow update, delete: if isAdminOrAbove(orgId);
      }

      // ── Bulletins ───────────────────────────────────────────────────────────
      match /bulletins/{bulletinId} {
        allow read:  if isSuperAdmin() || isOrgMember(orgId);
        allow write: if isModeratorOrAbove(orgId);
      }

      // ── News Posts ──────────────────────────────────────────────────────────
      match /newsPosts/{postId} {
        allow read:   if isSuperAdmin() || isOrgMember(orgId);

        // Members can create their own posts (group leader/teacher permissions
        // enforced at app layer via customRoles field)
        allow create: if isOrgMember(orgId)
                      && request.resource.data.organizationId == orgId
                      && request.resource.data.authorId == request.auth.uid;

        // Authors can edit their own posts; admins can edit any
        allow update: if isAdminOrAbove(orgId)
                      || (isOrgMember(orgId)
                          && resource.data.authorId == request.auth.uid);

        allow delete: if isAdminOrAbove(orgId)
                      || (isOrgMember(orgId)
                          && resource.data.authorId == request.auth.uid);
      }

      // ── Reminders / Broadcasts ──────────────────────────────────────────────
      // Security model:
      //   - Any org member may read published reminders / their own.
      //   - Holders of broadcastReminders (or admins) may create reminders.
      //       · They may always create a `pending` reminder (submit for review).
      //       · They may create a `published` reminder only if they can publish
      //         directly — i.e. they hold approveReminders, are an admin, OR the
      //         org does not require reminder approval.
      //   - Holders of approveReminders (or admins) may update reminders
      //     (approve / reject). Delivery writes (deliveredAt/publishedAt) are
      //     performed by Cloud Functions via the Admin SDK, which bypass rules.
      // ── Notification History ────────────────────────────────────────────────
      // Server-written archive of expired, recalled, and dismissed notifications.
      match /notification_history/{historyId} {
        allow read: if isAdminOrAbove(orgId)
                    || (isSignedIn()
                        && resource.data.createdBy == request.auth.uid)
                    || (isSignedIn()
                        && resource.data.userId == request.auth.uid);
        allow write: if false;
      }

      match /reminders/{reminderId} {
        allow read:   if isSuperAdmin() || isOrgMember(orgId);

        allow create: if (
                        (isAdminOrAbove(orgId)
                          || hasClaimedPermission('broadcastReminders'))
                        && request.resource.data.createdBy == request.auth.uid
                        && (
                          request.resource.data.status == 'pending'
                          || (request.resource.data.status == 'published'
                              && canPublishRemindersDirectly(orgId))
                        )
                      )
                      || canCreateGroupLeaderReminder(orgId);

        allow update: if isAdminOrAbove(orgId)
                      || hasClaimedPermission('approveReminders');

        allow delete: if isAdminOrAbove(orgId)
                      || (hasClaimedPermission('broadcastReminders')
                          && resource.data.createdBy == request.auth.uid)
                      || (resource.data.createdBy == request.auth.uid
                          && resource.data.get('audienceType', '') == 'group'
                          && isGroupLeader(orgId, resource.data.get('audienceId', '')));

        // Recipient responses — written via submitReminderResponse callable.
        match /responses/{userId} {
          allow read: if isAdminOrAbove(orgId)
                      || (isSignedIn() && request.auth.uid == userId)
                      || (isSignedIn()
                          && get(/databases/$(database)/documents/organizations/$(orgId)/reminders/$(reminderId)).data.createdBy == request.auth.uid);
          allow write: if false;
        }
      }

      // ── Group Chat Messages ─────────────────────────────────────────────────
      match /messages/{threadId} {
        allow read:   if isSuperAdmin() || isOrgMember(orgId);
        allow create: if isAdminOrAbove(orgId);
        allow update: if isAdminOrAbove(orgId);
        allow delete: if isAdminOrAbove(orgId);

        match /entries/{messageId} {
          allow read:   if isSuperAdmin() || isOrgMember(orgId);
          allow create: if isOrgMember(orgId)
                        && request.resource.data.senderId == request.auth.uid;
          allow update: if isAdminOrAbove(orgId)
                        || (isOrgMember(orgId)
                            && resource.data.senderId == request.auth.uid);
          allow delete: if isAdminOrAbove(orgId);
        }
      }

      // ── Direct Messages ─────────────────────────────────────────────────────
      match /directMessages/{threadId} {
        allow read: if isSuperAdmin()
                    || (isOrgMember(orgId)
                        && request.auth.uid in resource.data.participantIds);

        allow create: if isOrgMember(orgId)
                      && request.auth.uid in request.resource.data.participantIds
                      && request.resource.data.organizationId == orgId;

        allow update: if isSuperAdmin()
                      || (isOrgMember(orgId)
                          && request.auth.uid in resource.data.participantIds);

        allow delete: if isAdminOrAbove(orgId);

        match /entries/{messageId} {
          // get() check validates the user is a thread participant before reading messages
          allow read: if isSuperAdmin()
                      || (isOrgMember(orgId)
                          && request.auth.uid in
                             get(/databases/$(database)/documents/organizations/$(orgId)/directMessages/$(threadId)).data.participantIds);

          allow create: if isOrgMember(orgId)
                        && request.resource.data.senderId == request.auth.uid
                        && request.auth.uid in
                           get(/databases/$(database)/documents/organizations/$(orgId)/directMessages/$(threadId)).data.participantIds;

          allow update: if isAdminOrAbove(orgId)
                        || (isOrgMember(orgId)
                            && resource.data.senderId == request.auth.uid);

          allow delete: if isAdminOrAbove(orgId);
        }
      }

      // ── Blocked Users ───────────────────────────────────────────────────────
      match /blockedUsers/{blockId} {
        allow read:  if isAdminOrAbove(orgId);
        allow write: if isAdminOrAbove(orgId);
      }

      // ── Community Rules ─────────────────────────────────────────────────────
      match /communityRules/{ruleId} {
        allow read:  if isSuperAdmin() || isOrgMember(orgId);
        allow write: if isAdminOrAbove(orgId);
      }
    }

    // ── Global Language Database ──────────────────────────────────────────────
    // Read by any authenticated user; write by Super Admin only
    match /languages/{languageCode} {
      allow read:  if isSignedIn();
      allow write: if isSuperAdmin();

      match /strings/{stringKey} {
        allow read:  if isSignedIn();
        allow write: if isSuperAdmin();
      }
    }

    // ── Platform Collection (Super Admin only) ────────────────────────────────
    match /platform/{document=**} {
      allow read, write: if isSuperAdmin();
    }

    // ── Group members (collection group) ────────────────────────────────────
    // Lets any member query their own roster rows across all groups via
    // collectionGroup('members'). Document ID is the member's userId.
    match /{path=**}/members/{memberId} {
      allow read: if isSignedIn() && request.auth.uid == memberId;
    }

    // ── Role Assignments (collection group) ─────────────────────────────────
    // Required so org admins can query roleAssignments across all users via
    // collectionGroup(). A plain nested match rule is insufficient for
    // collection group queries — Firestore requires a wildcard-path rule.
    // Allows legacy role-claim admins OR RBAC manageRoles permission holders.
    // Note: isSuperAdmin() and isOrgAdmin() cannot be used here because
    // collection group queries have no orgId in scope.
    match /{path=**}/roleAssignments/{assignmentId} {
      allow read: if isSignedIn()
                  && (
                    isSuperAdmin()
                    || request.auth.token.get('role', '') in
                       ['admin', 'super_admin', 'owner']
                    || hasClaimedPermission('manageRoles')
                  );
    }

    // ── Default deny — reject all unmatched paths ─────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
